{
  "name": "@gatekeeper-dev/cli",
  "version": "0.1.0",
  "description": "Contract-aware merge gate for multi-repo organizations. Declare cross-repo contracts once; every diff is checked against them deterministically.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "gatekeeper": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "schema",
    "action.yml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/picomatch": "^3.0.1",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
